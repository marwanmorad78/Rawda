# DATABASE_PORT=3306

ADMIN_URL=manager-portal/
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_MEDIA_ROOT=
DJANGO_SERVE_MEDIA=False

STORE_NAME=Al Rawda Center
DEFAULT_FROM_EMAIL=no-reply@alrawdacenter.local

INVOICE_PRINT_ENABLED=False
INVOICE_PRINT_SERVICE_URL=http://127.0.0.1:5050/print-order
INVOICE_PRINT_SERVICE_TOKEN=change-this-shared-print-token
INVOICE_PRINT_TIMEOUT_SECONDS=3
